# Database
DB_HOST=db
DB_PORT=5432
DB_USER=finance
DB_PASSWORD=changeme
DB_NAME=finance_tracker
# Local dev only; for prod use sslmode=require
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# JWT (must be at least 32 chars; leave empty here so misconfigured deploys fail fast)
JWT_SECRET=

# Set to "false" for local HTTP dev so the refresh cookie is sent over http://.
# Keep unset (default true) in production so the cookie is only sent over HTTPS.
COOKIE_SECURE=true

# Invite codes (comma-separated)
INVITE_CODES=my-invite-code

# Backend
BACKEND_PORT=8080

# Container registry (for prod builds)
IMAGE_REGISTRY=ghcr.io/your-github-username

# URL prefix the app is served under (e.g. /finance/ when behind a reverse proxy).
# Feeds the Vite frontend build (as VITE_BASE_PATH) and the backend runtime (as BASE_PATH),
# so the refresh cookie's Path matches the actual request URL.
BASE_PATH=/
EXCHANGE_RATE_SYNC_MODE=endpoint
EXCHANGE_RATE_SYNC_TOKEN=your-exchange-rate-sync-token
